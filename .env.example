# Flask Backend
FLASK_SECRET_KEY=your_super_secret_key_here
FLASK_DEBUG=True
FLASK_PORT=5000

# Anthropic Claude API (for web chatbot)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram Bot - TelebotAPI
TELEBOT_TOKEN=your_telebot_token_here
TELEBOT_ADMIN_IDS=123456789,987654321

# Telegram Bot - Aiogram
AIOGRAM_TOKEN=your_aiogram_bot_token_here
AIOGRAM_ADMIN_IDS=123456789,987654321

# Payment (Telegram Payments)
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token_here

# Database paths
TELEBOT_DB_PATH=bot_telebot/shop.db
AIOGRAM_DB_PATH=bot_aiogram/shop.db
BACKEND_DB_PATH=backend/shop.db